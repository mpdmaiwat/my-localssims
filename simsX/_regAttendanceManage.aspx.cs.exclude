    //protected void gvStudentList_RowCommand(object sender, GridViewCommandEventArgs e)
    //{
    //    if (e.CommandName == "UpdateRow")
    //    {
    //        int rowIndex = ((GridViewRow)((LinkButton)e.CommandSource).NamingContainer).RowIndex;
    //    }
    //}

    protected void lnkSetDate_Click(object sender, EventArgs e)
    {
        display_Attendance_Date_Selected();
    }


    private void DISPLAY_SEARCH_STUDENT(string _studname, DateTime _datelog)
    {
        DataTable dt = oAttendance.GET_ATTENDANCE_ALL_DATE(_datelog);

        DataView dv = dt.DefaultView;

        dv.RowFilter = "studname like '%" + _studname + "%'";

        if (dv.Count > 0)
        {
            gvStudentList.DataSource = dt;
            gvStudentList.DataBind();
            txtSearch.Text = "";
        }
        else
        {
            //No Found
            display_Attendance_All_TODAY();
            ScriptManager.RegisterClientScriptBlock(this, this.GetType(), "msg", "<script>alert('Student not found in this date');</script>", false);
            txtDateApplied.Text = oSystem.GetServerDate().ToShortDateString();
            
            
        }

    }
}