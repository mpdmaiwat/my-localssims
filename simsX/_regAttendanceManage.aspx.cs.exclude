using System;
using System.Collections.Generic;
using System.Linq;
using System.Web;
using System.Web.UI;
using System.Web.UI.WebControls;
using System.Data;
using SIMSBDAL;

public partial class regAttendanceManage : System.Web.UI.Page
{
    xSystem oSystem = new xSystem();
    Attendance oAttendance = new Attendance();

  

   
    
    protected void Page_Load(object sender, EventArgs e)
    {
        
        if (!IsPostBack)
        {
            display_Attendance_All_TODAY();
            txtDateApplied.Text = oSystem.GetServerDate().ToShortDateString(); 
        }

    }


    private void display_Attendance_All_TODAY()
    {
        DataTable dt = oAttendance.GET_ATTENDANCE_ALL_TODAY();

        gvStudentList.DataSource = dt;
        gvStudentList.DataBind();
    }

    private void display_Attendance_Date_Selected()
    {
        if(!string.IsNullOrEmpty(txtDateApplied.Text))
        {
        DataTable dt = oAttendance.GET_ATTENDANCE_ALL_DATE(Convert.ToDateTime(txtDateApplied.Text));
        
        gvStudentList.DataSource = dt;
        gvStudentList.DataBind();
            }
        else
        {
        ScriptManager.RegisterClientScriptBlock(this, this.GetType(), "msg", "<script>alert('Please Select Date');</script>", false);
        }
        
    }
  
   
    protected void U_Search_Click(object sender, EventArgs e)
    {
     DISPLAY_SEARCH_STUDENT(txtSearch.Text, Convert.ToDateTime(txtDateApplied.Text));
    }

